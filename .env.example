# ═══════════════════════════════════════════════════════
#  Indian Waste Portal — environment template
#  Copy to .env.local (dev) and set real values for prod.
#  NEVER commit .env.local. This .example file is safe to commit.
# ═══════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000          # used in emails + payment-link callbacks (set to prod URL)
PASSWORD_SALT=change_this_to_a_long_random_string

# ── Database ─────────────────────────────────────────────
# The app auto-selects a backend (see lib/d1-db.js getDb):
#   DATABASE_URL set    → PostgreSQL   (production; DigitalOcean Managed PG, etc.)
#   TURSO_DATABASE_URL  → Turso/libSQL (serverless; Vercel)
#   neither             → local SQLite file (dev)
DATABASE_PATH=./wasteebank.db               # local dev SQLite file (better-sqlite3)

# PostgreSQL (recommended for production / heavy concurrent load — see DEPLOY-DIGITALOCEAN.md)
#   1) create a Managed Postgres DB   2) put its connection string below
#   3) node --env-file=.env.local scripts/init-postgres.mjs --pincodes
DATABASE_URL=                               # e.g. postgres://user:pass@host:25060/db?sslmode=require

# Turso (libSQL) — alternative for serverless hosts without a persistent disk.
#   1) turso db create indianwasteportal   2) turso db show --url indianwasteportal
#   3) turso db tokens create indianwasteportal   4) npm run init-turso
TURSO_DATABASE_URL=                         # e.g. libsql://indianwasteportal-you.turso.io
TURSO_AUTH_TOKEN=                           # from `turso db tokens create`

# ── Admin Command Center ─────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.in
ADMIN_PASSWORD=set-a-strong-password        # rotate before prod: scripts/rotate-admin.mjs
ADMIN_SECRET=long-random-hmac-secret        # signs the admin session cookie

# ── Razorpay (payments) ──────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx                  # Dashboard ▸ Webhooks ▸ secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxx     # same key id, exposed to the browser checkout
RETAINER_AMOUNT_PAISE=49900                  # booking retainer (₹499). ₹X = X*100

# ── CPCB portal + automation agent ───────────────────────
CPCB_PORTAL_URL=https://swm.cpcb.gov.in
AGENT_DEMO_MODE=false                        # true = synthetic ACK, never touches the real portal
AGENT_HEADLESS=true                          # false shows the browser (debug only)
# Filing mode: manual by default (consultant files on CPCB + records the ACK in admin).
# Set to true ONLY when the Playwright worker is running and you want the automated
# "Start Filing" button to appear in the admin console.
NEXT_PUBLIC_ENABLE_AUTO_FILING=false

# ── Queue worker (only for CF Queue prod mode) ───────────
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_QUEUE_ID=
POLL_INTERVAL_MS=10000
AGENT_BATCH_SIZE=3

# ── Notifications: WhatsApp / SMS ────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=                 # digits, country code first (e.g. 919054047272); EMPTY = WhatsApp button hidden
NOTIFY_PROVIDER=log                          # log (no send) | msg91 | gupshup
# MSG91
MSG91_AUTHKEY=
MSG91_WA_NUMBER=
MSG91_WA_TEMPLATE=iwp_booking_ack            # single fallback template
MSG91_WA_TEMPLATE_ACK=iwp_booking_ack        # per-type (see docs/whatsapp-templates.md)
MSG91_WA_TEMPLATE_OTP=iwp_action_link
MSG91_WA_TEMPLATE_ALERT=iwp_needs_attention
MSG91_SMS_TEMPLATE=
# Gupshup (alternative)
GUPSHUP_API_KEY=
GUPSHUP_SOURCE=
GUPSHUP_APP_NAME=IndianWastePortal
# Inbound WhatsApp webhook shared secret (?token=...)
WHATSAPP_WEBHOOK_SECRET=

# ── Transactional email ──────────────────────────────────
EMAIL_PROVIDER=log                           # log (no send) | resend
EMAIL_FROM=Indian Waste Portal <no-reply@yourdomain.in>
RESEND_API_KEY=

# ── Analytics (optional; env-gated) ──
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Error alerting (optional) ──
# Any JSON webhook (Slack/Discord/etc). When set, server + client errors POST here.
ERROR_WEBHOOK_URL=

# ── Client accounts ──
CLIENT_SECRET=long-random-client-session-secret
